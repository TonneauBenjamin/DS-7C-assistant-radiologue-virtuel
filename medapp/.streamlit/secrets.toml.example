# Copie ce fichier en .streamlit/secrets.toml et remplis avec tes vraies clés.
# Supabase > Project Settings > API :
#   - URL du projet          -> supabase_url
#   - clé "anon public"      -> supabase_anon_key
#   - clé "service_role"     -> supabase_service_role_key (recommandée en dev)

[supabase]
supabase_url = "https://xxxxxxxx.supabase.co"
supabase_anon_key = "eyJhbGci...ta_cle_anon..."

# FORTEMENT RECOMMANDÉ en développement : avec la clé service_role, la
# création de compte depuis l'app fonctionne TOUJOURS — les comptes naissent
# déjà confirmés, aucun email de confirmation à cliquer, quel que soit le
# réglage "Confirm email" du dashboard.
# ⚠️ Cette clé donne tous les droits : uniquement en local, jamais en ligne.
supabase_service_role_key = "eyJhbGci...ta_cle_service_role..."

# Optionnel : si la section [supabase] est absente ou incomplète, l'app
# démarre en MODE DÉMO LOCAL (SQLite + fichiers), sans configuration.


# ----------------------------------------------------------------------------
# Envoi d'email à la création d'un patient (optionnel).
# Choisis UN fournisseur. Section absente = pas d'email, app fonctionnelle.
# ----------------------------------------------------------------------------

# --- Option A : Resend (recommandé, https://resend.com) ---
[email]
provider = "resend"
from_address = "PneumoScan <onboarding@resend.dev>"   # ou ton domaine vérifié
resend_api_key = "re_xxxxxxxxxxxxxxxx"

# --- Option B : SMTP (ex. Gmail avec un "mot de passe d'application") ---
# [email]
# provider = "smtp"
# from_address = "ton.adresse@gmail.com"
# smtp_host = "smtp.gmail.com"
# smtp_port = 587
# smtp_user = "ton.adresse@gmail.com"
# smtp_password = "mot_de_passe_application_16_caracteres"
